  <caseSensitive value="true"/>
  <valueSet value="http://hl7.org/fhir/uv/cql/ValueSet/selectivity-form"/>
  <content value="complete"/>
  <concept>
    <code value="total"/>
    <display value="Total"/>
    <definition value="Indicates the query selectivity completely covers the criteria in the query (i.e. the query is in CNF/DNF, and all terms are sargeable)."/>
  </concept>
  <concept>
    <code value="conjunctive"/>
    <display value="Conjunctive"/>
    <definition value="Indicates the query selectivity represents criteria in Conjunctive Normal Form (CNF) (i.e. a conjunction of disjunctions)."/>
  </concept>
  <concept>
    <code value="disjunctive"/>
    <display value="Disjunctive"/>
    <definition value="Indicates the query selectivity represents criteria in Disjunctive Normal Form (DNF) (i.e. a disjunction of conjunctions)."/>
  </concept>
