  <description value="Codes representing the form of the description of the selectivity of an expression, either conjunctive or disjunctive."/>
  <jurisdiction>
    <coding>
      <system value="http://unstats.un.org/unsd/methods/m49/m49.htm"/>
      <code value="001"/>
      <display value="World"/>
